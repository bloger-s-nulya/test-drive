  <!-- Controls -->
  <div class="controls">
    <button class="btn btn--ghost" id="prevBtn">← Назад</button>
    <div class="progress-text" id="progressText">Слайд 1 из 8</div>
    <button class="btn btn--primary" id="nextBtn">Дальше →</button>
  </div>

</div>

<script>
  const slides = document.querySelectorAll('.slide');
  const total = slides.length;
  const dotsContainer = document.getElementById('dots');
  const progressLabel = document.getElementById('progressLabel');
  const progressText = document.getElementById('progressText');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');

  let current = 0;

  // build dots
  for (let i = 0; i < total; i++) {
    const dot = document.createElement('button');
    dot.className = 'dot';
    dot.setAttribute('aria-label', `Перейти к слайду ${i + 1}`);
    dot.addEventListener('click', () => goTo(i));
    dotsContainer.appendChild(dot);
  }

  function render() {
    slides.forEach((s, i) => {
      s.classList.toggle('is-active', i === current);
    });
    document.querySelectorAll('.dot').forEach((d, i) => {
      d.classList.toggle('is-active', i === current);
      d.classList.toggle('is-done', i < current);
    });
    progressLabel.textContent = `${current + 1} / ${total}`;
    progressText.textContent = `Слайд ${current + 1} из ${total}`;
    prevBtn.disabled = current === 0;
    if (current === total - 1) {
      nextBtn.textContent = 'К квизу →';
    } else {
      nextBtn.textContent = 'Дальше →';
    }
  }

  function goTo(index) {
    if (index < 0 || index >= total) return;
    current = index;
    render();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  prevBtn.addEventListener('click', () => goTo(current - 1));
  nextBtn.addEventListener('click', () => {
    if (current === total - 1) {
      // На последнем слайде кнопка ведёт к квизу — заглушка
      // Технический специалист должен заменить эту строку на реальный переход
      // window.location.href = 'URL_квиза';
      alert('Здесь будет переход к квизу «Твоя платформа-2026». Тех. специалисту заменить на реальный URL.');
      return;
    }
    goTo(current + 1);
  });

  // keyboard
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') goTo(current - 1);
    if (e.key === 'ArrowRight') goTo(current + 1);
  });

  render();
</script>

